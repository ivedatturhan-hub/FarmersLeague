@page
@model FarmersLeague.Pages.AddPlayerModel
@{
    ViewData["Title"] = "Add a New Player";
}

<h1>Add a New Player to the League</h1>

<form method="post">
    <div>
        <label>Player Name:</label>
        <input type="text" asp-for="InputName" required />
    </div>
    <br />

    <div>
    <label>Player Age:</label>
    <input type="number" asp-for="InputAge" required />
    </div>
    <br />

    <div class="form-group">
        <label>Player Position</label>

        <select asp-for="InputPosition" asp-items="Html.GetEnumSelectList<FarmersLeague.ML.Player.Positions>()" class="form-control">
            <option value="">-- Select a Position --</option>
        </select>
    </div>


    <div>
        <label>Base Attack (0-99):</label>
        <input type="number" asp-for="InputAttack" required />
    </div>
    <br />

    <div>
        <label>Base Defence (0-99):</label>
        <input type="number" asp-for="InputDefence" required />
    </div>
    <br />

    <div>
        <label>Player Market Value:</label>
        <input type="number" asp-for="InputMarketValue" step="any" required />
    </div>
    <br />

    <div>
        <label>Player Composure:</label>
        <input type="number" asp-for="InputComposure" required />
    </div>
    <br />

    <div>
        <label>Player Aggression:</label>
        <input type="number" asp-for="InputAggression" required />
    </div>
    <br />

    <button type="submit">Save Player</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <h3 style="color:red;">@Model.Message</h3>
}