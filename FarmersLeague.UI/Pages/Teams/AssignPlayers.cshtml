@page
@model AssignPlayersModel

<h2>Assign a player to @Model.TargetTeam.TeamName</h2>
<h4 class="text-success">Available Budget: €@Model.TargetTeam.Budget.ToString("N0") Million</h4>

<form method="post">

    <input type="hidden" asp-for="TargetTeamID" />

    <div>
        <label>Select Free Agent:</label>
        <select asp-for="SelectedPlayerID" required>
            <option value="">-- Choose a Player --</option>

            @foreach (var player in Model.PlayersWithNoTeam)
            {
                <option value="@player.PlayerID">@player.Name - @player.Position - (€@player.MarketValue m)</option>
            }
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Complete Transfer</button>
    <!-- A handy button to go back to the main teams list -->
    <a asp-page="/Teams/TeamPlayers" asp-route-id="@Model.TargetTeamID" class="btn btn-secondary">Back</a>

</form>