@page
@model AdminPlayersModel

<h1>Admin Dashboard: All Players</h1>
<hr />

<div class="mb-3">
    <a asp-page="/Players/AddPlayer" class="btn btn-success">
        + Add New Player
    </a>
</div>


<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Player ID</th>
            <th>Name</th>
            <th>Age</th>
            <th>Position</th>
            <th>Market Value</th>
            <th>Attack</th>
            <th>Defence</th>
            <th>Actions</th>


        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model.DisplayPlayers)
        {
            <tr>
                <td>@player.PlayerID</td>
                <td><strong>@player.Name</strong></td>
                <td>@player.Age</td>
                <td>@player.Position</td>
                <td> € @player.MarketValue m</td>
                <td>@player.BaseAttack</td>
                <td>@player.BaseDefence</td>

                <td>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@player.PlayerID">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

