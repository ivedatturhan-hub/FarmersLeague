@page
@model AdminPlayersModel

<h1>Admin Dashboard: All Players</h1>
<hr />

<div class="mb-3">
    <a asp-page="/Players/AddPlayer" class="btn btn-success">
        + Add New Player
    </a>
</div>


<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Player ID</th>
            <th>Name</th>
            <th>Age</th>
            <th>Position</th>
            <th>Market Value</th>
            <th>Attack</th>
            <th>Defence</th>
            <th>Actions</th>


        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model.PlayerList)
        {
            <tr>
                <td>@player.PlayerID</td>
                <td><strong>@player.Name</strong></td>
                <td>@player.Age</td>
                <td>@player.Position</td>
                <td> € @player.MarketValue m</td>
                <td>@player.BaseAttack</td>
                <td>@player.BaseDefence</td>


                <!-- edit button -->
                <td>
                    <!-- because i said asp-route-id, that button holds players id in the name of "id". so thats why i used PlayerToEdit = manager.GetPlayerById(id); in editplayer.cs  -->
                    <a asp-page="/Players/EditAdminPlayers" asp-route-id="@player.PlayerID" class="btn btn-warning btn-sm">Edit</a> // 

                     <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="id" value="@player.PlayerID" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete @player.Name?');">Delete</button>
                     </form>
                </td>
            </tr>
        }
    </tbody>
</table>

