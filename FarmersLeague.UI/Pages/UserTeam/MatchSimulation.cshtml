@page
@model FarmersLeague.UI.Pages.MatchSimulationModel
@{
    ViewData["Title"] = "Match Simulation";
}

<div class="container text-center mt-5">
    <h1 class="display-4 text-primary fw-bold">Farmers League Simulator</h1>
    <p class="lead mt-3">Click the button below to simulate the match between Team 1 and Team 2.</p>

    <!-- This form talks directly to your OnPost() method in the C# file -->
    <form method="post" class="mt-4">
        <button type="submit" class="btn btn-success btn-lg px-5 py-3 fs-4 fw-bold shadow">
            ⚽ Simulate Match! ⚽
        </button>
    </form>

    <!-- Here we check if the C# code gave us a result. If yes, we show the box! -->
    @if (!string.IsNullOrEmpty(Model.MatchResult))
    {
        <div class="alert alert-info mt-5 p-4 shadow-sm border-2">
            <h4 class="text-muted mb-3">Final Result</h4>
            <h1 class="display-5 fw-bold text-dark">@Model.MatchResult</h1>
        </div>
    }
</div>