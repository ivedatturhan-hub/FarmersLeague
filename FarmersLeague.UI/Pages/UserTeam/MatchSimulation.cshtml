@page
@model FarmersLeague.UI.Pages.MatchSimulationModel
@{
    ViewData["Title"] = "Match Simulation";
}

<div class="container text-center mt-5">
    <h1 class="display-4 text-primary fw-bold">Farmers League Simulator</h1>
    <p class="lead mt-3">Click the button below to simulate the match between Team 1 and Team 2.</p>

    <!-- This form talks directly to your OnPost() method in the C# file -->
    <form method="post" class="mt-4">
        <button type="submit" class="btn btn-success btn-lg px-5 py-3 fs-4 fw-bold shadow">
            ⚽ Simulate Match! ⚽
        </button>
    </form>

    <!-- Here we check if the C# code gave us a result. If yes, we show the box! -->
    <!-- NEW STATS DASHBOARD -->
    @if (Model.MatchResult != null)
    {
        // If it's an error, show a basic red box
        if (Model.MatchResult.FinalScore.StartsWith("Error"))
        {
            <div class="alert alert-danger" style="max-width: 500px;">
                @Model.MatchResult.FinalScore
            </div>
        }
        else
        {
            <div class="card" style="max-width: 500px;">
                <div class="card-header bg-light">
                    <h5 class="mb-0 text-center fw-bold">@Model.MatchResult.FinalScore</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-striped table-bordered text-center mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Stat</th>
                                <th>Host Team</th>
                                <th>Visitor Team</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Attack Power</strong></td>
                                <td>@Model.MatchResult.HostAttack</td>
                                <td>@Model.MatchResult.VisitorAttack</td>
                            </tr>
                            <tr>
                                <td><strong>Defence Power</strong></td>
                                <td>@Model.MatchResult.HostDefence</td>
                                <td>@Model.MatchResult.VisitorDefence</td>
                            </tr>
                            <tr>
                                <td><strong>Chances Created</strong></td>
                                <td class="text-success fw-bold">@Model.MatchResult.HostChances</td>
                                <td class="text-success fw-bold">@Model.MatchResult.VisitorChances</td>
                            </tr>
                            <tr>
                                <td><strong>Points in the League</strong></td>
                                <td class="text-success fw-bold">@Model.MatchResult.HostPoints</td>
                                <td class="text-success fw-bold">@Model.MatchResult.VisitorPoints</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>