@page
@model FarmersLeague.UI.Pages.UserTeam.TeamManagementModel
@{
    ViewData["Title"] = "Manage My Line-up";
}

<h2>Set Line-up & Tactics</h2>

<div asp-validation-summary="All" class="text-danger font-weight-bold"></div>

<form method="post">

    <div class="form-group mb-4">
        <label class="font-weight-bold">Formation:</label>
        <select asp-for="SelectedTactic" class="form-control w-25">
            <option value="4-4-2">4-4-2</option>
            <option value="4-3-3">4-3-3</option>
            <option value="3-5-2">3-5-2</option>
        </select>
    </div>

    <h4>Starting XI</h4>
    <div class="row">
        <div class="col-md-6">
            @for (int i = 0; i < 11; i++)
            {
                <label class="position-label font-weight-bold mt-2">@("") <span></span></label>

                <select name="StarterIds" class="player-select form-control mb-2">
                    <option value="0">-- Select Player --</option>

                    @foreach (var player in Model.PlayerOptions)
                    {
                        // Check if this player's ID matches the Starter ID for this specific position
                        if (Model.StarterIDs[i].ToString() == player.Value)
                        {
                            <option value="@player.Value" selected>@player.Text</option>
                        }
                        else
                        {
                            <option value="@player.Value">@player.Text</option>
                        }
                    }
                </select>
            }
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Save Line-up</button>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const dropdowns = document.querySelectorAll('.player-select');
            const tacticDropdown = document.getElementById('SelectedTactic');
            const positionLabels = document.querySelectorAll('.position-label span');

            // 1. Dynamic Formation Labels Dictionary
            const formations = {
                "4-4-2": ["Goalkeeper", "Defender", "Defender", "Defender", "Defender", "Midfielder", "Midfielder", "Midfielder", "Midfielder", "Striker", "Striker"],
                "4-3-3": ["Goalkeeper", "Defender", "Defender", "Defender", "Defender", "Midfielder", "Midfielder", "Midfielder", "Striker", "Striker", "Striker"],
                "3-5-2": ["Goalkeeper", "Defender", "Defender", "Defender", "Midfielder", "Midfielder", "Midfielder", "Midfielder", "Midfielder", "Striker", "Striker"]
            };

            function updateLabels() {
                const currentTactic = tacticDropdown.value;
                const currentPositions = formations[currentTactic];

                if (currentPositions) {
                    positionLabels.forEach(function (label, index) {
                        label.innerText = currentPositions[index];
                    });
                }
            }

            // 2. Duplicate Player Checker but ignores "0" because i want to be able to choose it more than once                  
            function updateDropdowns() {
            const selectedPlayerIds = [];

            dropdowns.forEach(d => {
                if (d.value !== "0" && d.value !== "") {
                    selectedPlayerIds.push(d.value);
                }
            });

            // 2. Loop through options and disable duplicates
            dropdowns.forEach(dropdown => {
                Array.from(dropdown.options).forEach(option => {

                    // THE FIX: We force the "0" option to ALWAYS be clickable
                    if (option.value === "0" || option.value === "") {
                        option.disabled = false;
                        return; // Stop checking this option and move to the next one
                    }

                    // Standard duplicate check for actual players
                    if (selectedPlayerIds.includes(option.value) && option.value !== dropdown.value) {
                        option.disabled = true;
                    } else {
                        option.disabled = false;
                    }
                });
            });
        }

            // Event Listeners
            tacticDropdown.addEventListener('change', updateLabels);
            dropdowns.forEach(dropdown => {
                dropdown.addEventListener('change', updateDropdowns);
            });

            // Initial run to set everything up on page load
            updateLabels();
            updateDropdowns();
        });
    </script>
}